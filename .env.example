# =============================================================================
# Finaura — Supabase Configuration
# =============================================================================
# Copy this file to .env.local and fill in your Supabase project credentials.
#
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Get URL + anon key from Project Settings → API
# 4. Configure Auth redirect URLs (see supabase/README.md)
# =============================================================================

# Supabase (required for auth, database, storage)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database password (optional — for npm run db:apply)
# Find in Supabase Dashboard → Project Settings → Database
# SUPABASE_DB_PASSWORD=your-database-password
# Or set a full connection string:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Service role key (optional — for npm run e2e:verify auto-confirm in CI/local)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (optional — subscription billing)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
